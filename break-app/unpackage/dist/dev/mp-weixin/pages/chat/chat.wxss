  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}
.send-button.data-v-0a633310 {
  width: 120rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}
.send-button.disabled.data-v-0a633310 {
  opacity: 0.5;
  background: #ccc;
}
.send-button.data-v-0a633310:active:not(.disabled) {
