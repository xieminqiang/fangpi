
/* 容器 */
.container.data-v-af28c7f4 {
	height: 100vh;
	background-color: #f6f8f7;
	box-sizing: border-box;
	display: flex;
	flex-direction: column;
	overflow: hidden;
}

/* 滚动内容区域 */
.scroll-content.data-v-af28c7f4 {
	flex: 1;
	height: 0; /* 重要：让 flex 子元素正确计算高度 */
	overflow-y: auto;
	-webkit-overflow-scrolling: touch; /* iOS 平滑滚动 */
	/* 优化滚动性能 */
	will-change: scroll-position;
	/* 确保内容区域有足够的空间 */
	min-height: 0;
}

/* 动画 */
@keyframes fadeIn-af28c7f4 {
from {
		opacity: 0;
		transform: translateY(-30rpx);
}
to {
		opacity: 1;
		transform: translateY(0);
}
}
@keyframes slideIn-af28c7f4 {
from {
		opacity: 0;
		transform: translateY(50rpx) scale(0.95);
}
to {
		opacity: 1;
		transform: translateY(0) scale(1);
}
}
.fade-in.data-v-af28c7f4 {
	animation: fadeIn-af28c7f4 0.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}


/* Header with Gradient */
.header-gradient.data-v-af28c7f4 {
	background: linear-gradient(to bottom, #d4f1f4 0%, #fffacd 100%);
	padding: 28rpx;
	padding-bottom: 16rpx;
	flex-shrink: 0; /* 防止被压缩 */
}
.header-content.data-v-af28c7f4 {
	display: flex;
	flex-direction: column;
	gap: 8rpx;
	padding-top: 45rpx;
}
.title.data-v-af28c7f4 {
	color: #0d1b14;
	font-size: 32rpx;
	font-weight: bold;
	line-height: 1.2;
}
.subtitle.data-v-af28c7f4 {
	color: rgba(13, 27, 20, 0.8);
	font-size: 28rpx;
	padding-bottom: 24rpx;
}

/* Period Selector */
.period-selector.data-v-af28c7f4 {
	background: linear-gradient(to bottom, #fffacd 0%, #f6f8f7 100%);
	padding: 20rpx 28rpx;
	flex-shrink: 0; /* 防止被压缩 */
}





/* Chart Card */
.chart-card.data-v-af28c7f4 {
	display: flex;
	flex-direction: column;
	gap: 20rpx;
	
	margin: 20rpx;	
	background-color: #f6f8f7;
	border: 2rpx solid rgba(138, 245, 191, 0.2);
	border-radius: 32rpx;
	padding: 20rpx 0;
	/* 响应式间距 */
	flex-shrink: 0;
}
.chart-title.data-v-af28c7f4 {
	color: #0d1b14;
	font-size: 28rpx;
	font-weight: 600;
	margin-left: 20rpx;
	margin-top: 0;
	margin-bottom: 10rpx;
}

/* Trend Chart - ECharts */
.trend-chart-echart.data-v-af28c7f4 {
	position: relative;
	width: 100%;
	min-height: 300rpx;
	max-height: 500rpx;
	border-radius: 16rpx;
	overflow: visible; /* 改为 visible，避免裁剪图表内容 */
	/* 确保图表容器有明确的定位上下文 */
	z-index: 1;
	/* 响应式高度调整 */
	height: auto;
	/* 确保容器有明确的尺寸 */
	box-sizing: border-box;
}

/* 图表 Loading 遮罩层 */
.chart-loading.data-v-af28c7f4 {
	position: absolute;
	top: 0;
	left: 0;
	right: 0;
	bottom: 0;
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
	background-color: rgba(246, 248, 247, 0.9);
	border-radius: 16rpx;
	z-index: 10;
}

/* Loading 旋转动画 */
.loading-spinner.data-v-af28c7f4 {
	width: 60rpx;
	height: 60rpx;
	border: 4rpx solid rgba(138, 245, 191, 0.2);
	border-top-color: #8af5bf;
	border-radius: 50%;
	animation: spin-af28c7f4 1s linear infinite;
	margin-bottom: 20rpx;
}
@keyframes spin-af28c7f4 {
0% {
		transform: rotate(0deg);
}
100% {
		transform: rotate(360deg);
}
}
.loading-text.data-v-af28c7f4 {
	color: rgba(13, 27, 20, 0.6);
	font-size: 24rpx;
	font-weight: 500;
}

/* 临时数据显示 */
.trend-data-display.data-v-af28c7f4 {
	display: flex;
	justify-content: space-around;
	align-items: center;
	padding: 20rpx 20rpx;
	background: linear-gradient(to bottom, rgba(138, 245, 191, 0.05) 0%, rgba(138, 245, 191, 0) 100%);
	border-radius: 16rpx;
}
.data-point-item.data-v-af28c7f4 {
	display: flex;
	flex-direction: column;
	align-items: center;
	gap: 12rpx;
}
.data-time.data-v-af28c7f4 {
	color: rgba(138, 245, 191, 0.8);
	font-size: 24rpx;
	font-weight: bold;
}
.data-value.data-v-af28c7f4 {
	color: #0d1b14;
	font-size: 28rpx;
	font-weight: bold;
	padding: 12rpx 20rpx;
	background: rgba(138, 245, 191, 0.2);
	border-radius: 12rpx;
}



/* AI Summary Card */
.ai-card.data-v-af28c7f4 {
	position: relative;
	padding: 20rpx;
	margin: 0 20rpx 40rpx 20rpx;
	background: linear-gradient(135deg, #FFDAB9 0%, #A7C7E7 100%);
	border-radius: 32rpx;
	overflow: hidden;
	/* 响应式调整 */
	flex-shrink: 0;
}
.ai-header.data-v-af28c7f4 {
	display: flex;
	align-items: center;
	gap: 24rpx;
	margin-bottom: 32rpx;
}
.ai-icon.data-v-af28c7f4 {
	width: 48rpx;
	height: 48rpx;
}
.ai-title.data-v-af28c7f4 {
	color: #0d1b14;
	font-size: 28rpx;
	font-weight: bold;
}
.ai-content.data-v-af28c7f4 {
	display: flex;
	flex-direction: column;
	gap: 20rpx;
}
.ai-item.data-v-af28c7f4 {
	color: rgba(13, 27, 20, 0.8);
	font-size: 28rpx;
}
.ai-highlight.data-v-af28c7f4 {
	font-weight: bold;
	color: #0d1b14;
}
.ai-bg-icon.data-v-af28c7f4 {
	position: absolute;
	right: -48rpx;
	bottom: -48rpx;
	font-size: 256rpx;
	opacity: 0.1;
	transform: rotate(15deg);
}

