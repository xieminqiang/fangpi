
.ai-fx-container.data-v-38a9e170 {
  height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #FFF9C4 50%, #E1F5FE 100%);
  position: relative;
  box-sizing: border-box;
}

/* Header Section */
.header-section.data-v-38a9e170 {
  padding: 0rpx 32rpx 40rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.header-decoration.data-v-38a9e170 {
  position: absolute;
  color: rgba(255, 255, 255, 0.3);
  opacity: 0.5;
}
.header-decoration-img.data-v-38a9e170 {
  position: absolute;
  opacity: 0.3;
}
.decoration-1.data-v-38a9e170 {
  top: -20rpx;
  left: -40rpx;
  width: 180rpx;
  height: 180rpx;
}
.header-title.data-v-38a9e170 {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #1B5E20;
  margin-bottom: 16rpx;
}
.header-subtitle.data-v-38a9e170 {
  display: block;
  font-size: 28rpx;
  color: #2E7D32;
  margin-bottom: 20rpx;
}
.header-desc.data-v-38a9e170 {
  display: block;
  font-size: 24rpx;
  color: #558B2F;
  line-height: 1.6;
}

/* Loading Section */
.loading-section.data-v-38a9e170 {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}
.loading-spinner.data-v-38a9e170 {
  width: 80rpx;
  height: 80rpx;
  border: 8rpx solid rgba(27, 94, 32, 0.2);
  border-top-color: #1B5E20;
  border-radius: 50%;
  animation: spin-38a9e170 1s linear infinite;
  margin-bottom: 32rpx;
}
@keyframes spin-38a9e170 {
0% { transform: rotate(0deg);
}
100% { transform: rotate(360deg);
}
}
.loading-text.data-v-38a9e170 {
  font-size: 28rpx;
  color: #558B2F;
}

/* Content Section */
.content-section.data-v-38a9e170 {
  padding: 0 32rpx 40rpx;
}

/* Analysis Card */
.analysis-card.data-v-38a9e170 {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}
.health-card.data-v-38a9e170 {
  background: linear-gradient(135deg, rgba(168, 230, 207, 0.3), rgba(255, 255, 255, 0.95));
}
.card-header.data-v-38a9e170 {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.card-icon.data-v-38a9e170 {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}
.card-title.data-v-38a9e170 {
  font-size: 32rpx;
  font-weight: bold;
  color: #1B5E20;
}


