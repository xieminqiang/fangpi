
.me-container.data-v-c8e26b33 {
  height: 100vh;
  background: linear-gradient(180deg, #A8E6CF 0%, #FFFACD 100%);
  position: relative;
}

/* Header Area */
.header-area.data-v-c8e26b33 {
  padding: 110rpx 32rpx 32rpx;
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
}
.avatar.data-v-c8e26b33 {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid white;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  flex-shrink: 0;
  transition: all 0.3s ease;
}
.avatar.data-v-c8e26b33:active {
  transform: scale(0.95);
  opacity: 0.9;
}
.header-info.data-v-c8e26b33 {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.nickname-row.data-v-c8e26b33 {
  display: flex;
  align-items: center;
  gap: 12rpx;
  transition: all 0.3s ease;
}
.nickname-row.data-v-c8e26b33:active {
  opacity: 0.7;
}
.nickname.data-v-c8e26b33 {
  font-size: 34rpx;
  font-weight: bold;
  color: #5D5D5D;
}
.nickname-arrow.data-v-c8e26b33 {
  width: 38rpx;
  height:38rpx
}
.info-row.data-v-c8e26b33 {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}
.info-badge.data-v-c8e26b33 {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 20rpx;
  padding: 8rpx 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}
.info-badge.data-v-c8e26b33:active {
  transform: scale(0.95);
  opacity: 0.9;
}
.info-label.data-v-c8e26b33 {
  font-size: 22rpx;
  color: #5D5D5D;
  font-weight: 500;
}
.info-value.data-v-c8e26b33 {
  font-size: 22rpx;
  color: #1B5E20;
  font-weight: bold;
}
.level-info.data-v-c8e26b33 {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 20rpx;
  padding: 8rpx 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  align-self: flex-start;
}
.level-info.data-v-c8e26b33:active {
  transform: scale(0.95);
  opacity: 0.9;
}
.level-icon.data-v-c8e26b33 {
  width: 32rpx;
  height: 32rpx;
}
.level-name.data-v-c8e26b33 {
  font-size: 24rpx;
  font-weight: 600;
  color: #1B5E20;
}
.arrow-right.data-v-c8e26b33 {
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
}

/* Achievement Section */
.achievement-section.data-v-c8e26b33 {
  padding: 0 32rpx 32rpx;
  margin-top: 50rpx;
}
.section-header.data-v-c8e26b33 {
 
  display: flex;
  justify-content: space-between;
  
  margin-bottom: 24rpx;
}
.view-all-btn.data-v-c8e26b33 {
  background: rgba(255, 255, 255, 0.8);

  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-left: 20rpx;
  padding-right: 10rpx;
}
.view-all-btn.data-v-c8e26b33::after {
  border: none;
}
.view-all-btn.data-v-c8e26b33:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.9);
}
.btn-text.data-v-c8e26b33 {
  font-size: 20rpx;
  color: #5D5D5D;
  font-weight: 500;
}
.btn-arrow.data-v-c8e26b33 {
  width: 24rpx;
  height: 24rpx;
}
.achievement-grid.data-v-c8e26b33 {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 32rpx;
  text-align: center;
  margin-bottom: 40rpx;
}
.achievement-item.data-v-c8e26b33 {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  transition: all 0.3s ease;
}
.achievement-item.data-v-c8e26b33:active {
  transform: scale(0.95);
}
.achievement-badge.data-v-c8e26b33 {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}
.achievement-badge-1.data-v-c8e26b33 {
  background: #A8E6CF;
}
.achievement-badge-2.data-v-c8e26b33 {
  background: #FFD3B6;
}
.achievement-badge-3.data-v-c8e26b33 {
  background: #FFFACD;
}
.achievement-badge-locked.data-v-c8e26b33 {
  background: #D1D5DB;
  opacity: 0.5;
}
.achievement-emoji.data-v-c8e26b33 {
  font-size: 60rpx;
}
.achievement-icon.data-v-c8e26b33 {
  width: 60rpx;
  height: 60rpx;
  border-radius: 8rpx;
}
.achievement-label.data-v-c8e26b33 {
  font-size: 24rpx;
  font-weight: 600;
  color: #5D5D5D;
}
.achievement-label-locked.data-v-c8e26b33 {
  color: #9CA3AF;
}

/* AI Entry Section */
.ai-entry-section.data-v-c8e26b33 {
  padding: 0 32rpx 40rpx;
}
.ai-entry-card.data-v-c8e26b33 {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: linear-gradient(135deg, #FFC3A0, #A8E6CF);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}
.ai-entry-card.data-v-c8e26b33:active {
  transform: scale(0.98);
  opacity: 0.9;
}
.entry-icon.data-v-c8e26b33 {
  width: 64rpx;
  height: 64rpx;
}
.entry-content.data-v-c8e26b33 {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.entry-title.data-v-c8e26b33 {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
  display: block;
}
.entry-desc.data-v-c8e26b33 {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
}
.entry-arrow.data-v-c8e26b33 {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

/* 成就详情弹窗样式 */
.achievement-detail-popup.data-v-c8e26b33 {
  width: 650rpx;
  background: #f6f8f7;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}
.popup-header.data-v-c8e26b33 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #A8E6CF 0%, #F9F871 100%);
}
.popup-title.data-v-c8e26b33 {
  font-size: 32rpx;
  font-weight: 600;
  color: #0d1b14;
}
.popup-close.data-v-c8e26b33 {
  font-size: 40rpx;
  color: #0d1b14;
  padding: 10rpx;
}
.popup-content.data-v-c8e26b33 {
  padding: 40rpx;
}
.detail-gif-container.data-v-c8e26b33 {
  text-align: center;
  margin-bottom: 30rpx;
}
.detail-gif.data-v-c8e26b33 {
  width: 200rpx;
  height: 200rpx;
  border-radius: 20rpx;
}
.detail-emoji.data-v-c8e26b33 {
  font-size: 120rpx;
}
.detail-info.data-v-c8e26b33 {
  text-align: center;
  margin-bottom: 40rpx;
}
.detail-name.data-v-c8e26b33 {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #0d1b14;
  margin-bottom: 15rpx;
}
.detail-desc.data-v-c8e26b33 {
  display: block;
  font-size: 28rpx;
  color: #5D5D5D;
  line-height: 1.5;
  margin-bottom: 25rpx;
}
.detail-progress.data-v-c8e26b33 {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}
.progress-label.data-v-c8e26b33 {
  font-size: 26rpx;
  color: #5D5D5D;
  margin-right: 15rpx;
}
.progress-bar.data-v-c8e26b33 {
  width: 200rpx;
  height: 12rpx;
  background: rgba(115, 154, 76, 0.2);
  border-radius: 6rpx;
  overflow: hidden;
  margin-right: 15rpx;
}
.progress-fill.data-v-c8e26b33 {
  height: 100%;
  background: linear-gradient(90deg, #A8E6CF 0%, #8af5bf 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}
.progress-fill.completed.data-v-c8e26b33 {
  background: linear-gradient(90deg, #4CAF50 0%, #8BC34A 100%);
}
.progress-value.data-v-c8e26b33 {
  font-size: 26rpx;
  color: #739a4c;
  font-weight: bold;
}
.detail-reward.data-v-c8e26b33, .detail-unlock-time.data-v-c8e26b33 {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 15rpx;
}
.reward-label.data-v-c8e26b33, .unlock-label.data-v-c8e26b33 {
  font-size: 26rpx;
  color: #5D5D5D;
  margin-right: 10rpx;
}
.reward-value.data-v-c8e26b33 {
  font-size: 26rpx;
  color: #739a4c;
  font-weight: bold;
}
.unlock-value.data-v-c8e26b33 {
  font-size: 26rpx;
  color: #0d1b14;
}
.popup-actions.data-v-c8e26b33 {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}
.action-btn.data-v-c8e26b33 {
  flex: 1;
  padding: 20rpx 30rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}
.btn-icon.data-v-c8e26b33 {
  font-size: 28rpx;
}
.action-btn.primary.data-v-c8e26b33 {
  background: linear-gradient(135deg, #4CAF50 0%, #8BC34A 100%);
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(76, 175, 80, 0.3);
}
.action-btn.primary.data-v-c8e26b33:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 10rpx rgba(76, 175, 80, 0.4);
}
.action-btn.secondary.data-v-c8e26b33 {
  background: linear-gradient(135deg, #A8E6CF 0%, #F9F871 100%);
  color: #0d1b14;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.1);
}
.action-btn.secondary.data-v-c8e26b33:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.15);
}
.action-btn.disabled.data-v-c8e26b33 {
  background: linear-gradient(135deg, #E0E0E0 0%, #BDBDBD 100%);
  color: #9E9E9E;
  box-shadow: none;
  opacity: 0.6;
  cursor: not-allowed;
}
.action-btn.data-v-c8e26b33::after {
  border: none;
}

