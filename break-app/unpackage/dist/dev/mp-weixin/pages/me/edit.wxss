/* 底部按钮 */
.footer.data-v-f2be5884 {
  padding: 0 0 60rpx;
  box-sizing: border-box;
  width: 100%;
}
.save-btn.data-v-f2be5884 {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #A8E6CF 0%, #8af5bf 100%);
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(168, 230, 207, 0.4);
  display: flex;
  align-items: center;
