}
.section-label.data-v-f2be5884 {
  font-size: 28rpx;
  font-weight: 600;
  color: #1B5E20;
  margin-bottom: 24rpx;
  display: block;
}

/* 头像区域 */
.avatar-section.data-v-f2be5884 {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}
.avatar-wrapper.data-v-f2be5884 {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}
.btn-normal.data-v-f2be5884 {
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  line-height: 1;
  outline: none;
  box-shadow: none;
  border-radius: 50%;
  overflow: hidden;
  width: 200rpx;
  height: 200rpx;
  position: relative;
  display: block;
}
.btn-normal.data-v-f2be5884::after {
  border: none;
}
.avatar-image.data-v-f2be5884 {
  width: 200rpx;
  height: 200rpx;
