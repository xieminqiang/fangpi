
.points-container.data-v-f8d1908e {
  height: 100vh;
  background: linear-gradient(180deg, #A8E6CF 0%, #FFFACD 100%);
}

/* Header Section */
.header-section.data-v-f8d1908e {
  padding: 30rpx 32rpx 24rpx;
  text-align: center;
}
.header-title.data-v-f8d1908e {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #1B5E20;
  margin-bottom: 12rpx;
}
.header-subtitle.data-v-f8d1908e {
  display: block;
  font-size: 26rpx;
  color: #5D5D5D;
}

/* Points Display Section */
.points-display-section.data-v-f8d1908e {
  padding: 0 32rpx 32rpx;
}
.points-card.data-v-f8d1908e {
  background: linear-gradient(135deg, #4CAF50 0%, #8BC34A 100%);
  border-radius: 28rpx;
  padding: 50rpx 32rpx;
  text-align: center;
  box-shadow: 0 12rpx 32rpx rgba(76, 175, 80, 0.25);
  position: relative;
  overflow: hidden;
}
.points-card.data-v-f8d1908e::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  animation: shimmer-f8d1908e 3s infinite;
}
@keyframes shimmer-f8d1908e {
0% { transform: rotate(0deg);
}
100% { transform: rotate(360deg);
}
}
.points-icon-wrapper.data-v-f8d1908e {
  margin-bottom: 16rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}
.points-icon.data-v-f8d1908e {
  width: 64rpx;
  height: 64rpx;
  display: block;
}
.points-label.data-v-f8d1908e {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 12rpx;
}
.points-value.data-v-f8d1908e {
  display: inline-block;
  font-size: 88rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1;
  margin-right: 8rpx;
}
.points-unit.data-v-f8d1908e {
  display: inline-block;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  vertical-align: bottom;
  margin-bottom: 8rpx;
}

/* Detail Entry Section */
.detail-entry-section.data-v-f8d1908e {
  padding: 0 32rpx 32rpx;
}
.detail-entry-card.data-v-f8d1908e {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.85);
  border-radius: 20rpx;
  padding: 24rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}
.detail-entry-card.data-v-f8d1908e:active {
  transform: scale(0.98);
